# Supabase (Project Settings → API)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NO la anon key)

# Embeddings — endpoint compatible OpenAI /embeddings (vía la capa proxy/adaptador).
# El modelo DEBE producir 1536 dimensiones para casar con schema.sql.
PM_EMBEDDINGS_URL=https://api.openai.com/v1/embeddings
PM_EMBEDDINGS_KEY=sk-...
PM_EMBEDDINGS_MODEL=text-embedding-3-small
PM_EMBEDDINGS_DIM=1536

# (Opcional) LLM para descripciones ≤2 oraciones de código. Si se omite, se usa la firma.
# PM_LLM_URL=https://api.openai.com/v1/chat/completions
# PM_LLM_KEY=sk-...
# PM_LLM_MODEL=gpt-4o-mini
