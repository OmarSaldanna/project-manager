# Copia este archivo a .env (en la raíz del plugin) y complétalo. El servidor MCP y los CLIs
# cargan este .env automáticamente (Node lo lee, no Claude Code). NUNCA subas tu .env.

# Supabase (Project Settings → API)
SUPABASE_URL=https://fnlnjufexnwshvbjlqlk.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NO la anon key)

# Embeddings — endpoint compatible OpenAI /embeddings (vía la capa proxy/adaptador).
# El modelo DEBE producir 1536 dimensiones para casar con schema.sql.
PM_EMBEDDINGS_URL=https://api.openai.com/v1/embeddings
PM_EMBEDDINGS_KEY=sk-...
PM_EMBEDDINGS_MODEL=text-embedding-3-small
PM_EMBEDDINGS_DIM=1536

# (Opcional) LLM para descripciones ≤2 oraciones de código. Si se omite, se usa la firma.
# PM_LLM_URL=https://api.openai.com/v1/chat/completions
# PM_LLM_KEY=sk-...
# PM_LLM_MODEL=gpt-4o-mini

# Repo central de PRDs (enginecx_prd) — SOLO la ubicación del repo (no es un secreto).
# El bin prd-sync clona/commitea/pushea con la identidad y credenciales de git YA configuradas
# en tu equipo (credential helper / gh / SSH); NO se guardan credenciales de GitHub aquí.
# El comando /instalar verifica que tu git tenga usuario configurado y acceso a este repo.
ENGINECX_PRD_REPO=https://github.com/ORG/enginecx_prd.git
